{
  "name": "@dualmark/cli",
  "version": "0.1.0",
  "description": "Conformance test runner for the AEO spec. `dualmark verify <url>` scores any site against the AEO Specification.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dodopayments/dualmark.git",
    "directory": "packages/cli"
  },
  "homepage": "https://dualmark.dev",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js",
      "require": "./dist/verify.cjs"
    }
  },
  "bin": {
    "dualmark": "./dist/cli.js"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@dualmark/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": ["aeo", "conformance", "cli", "dualmark"]
}
